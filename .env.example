# ForgeFlow configuration — copy to `.env` and fill in as needed.
# ForgeFlow runs fully in mock mode WITHOUT any of these keys.

# Default provider when a workflow does not specify one: mock | openai | anthropic
FORGEFLOW_PROVIDER=mock

# Where ForgeFlow stores its local SQLite DB (runs, memory). Defaults to ./.forgeflow
# FORGEFLOW_HOME=.forgeflow

# --- Real LLM providers (optional) ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
